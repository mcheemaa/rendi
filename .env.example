# Copy to .env.development.local and fill in. Never commit real values.
# Every variable is documented in docs/DEPLOYMENT.md: what it is, where to get it.

# The agent's model (conversation titles ride the same key)
ANTHROPIC_API_KEY=

# Image generation (optional; the agent simply works without images)
GEMINI_API_KEY=

# Trigger.dev, the agent's runtime. Put your project ref in trigger.config.ts,
# then `npx trigger.dev@4.5.4 login`. The secret key is per environment.
TRIGGER_SECRET_KEY=

# ClickHouse. Admin credentials run seeds and dataset loads; rendi_reader is
# the guarded read-only role every user-facing query uses; the telemetry user
# is an INSERT-only span writer. scripts/seed-clickhouse.mts creates both
# roles with the passwords you set here.
CLICKHOUSE_URL=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_READER_PASSWORD=
CLICKHOUSE_TELEMETRY_PASSWORD=

# Neon Postgres: direct for migrations and workers, pooled for the app
DATABASE_URL=
DATABASE_URL_CONNECTION_POOLING=

# Agent model id
RENDI_MODEL=claude-opus-4-8

# HMAC secret behind render and share tokens (openssl rand -hex 32)
RENDER_TOKEN_SECRET=

# Public app origin; tools persist absolute URLs built from it
RENDI_APP_URL=http://localhost:3000

# Agent-sent email via Resend (optional). The sender address lives in
# trigger/tools/send-email.ts; point it at your verified domain.
RESEND_API_KEY=

# Commit sync (optional): a zero-scope token raises GitHub rate limits and
# reaches your private repos
GITHUB_TOKEN=

# ClickStack (optional): dual-emit telemetry spans to an OTLP collector,
# e.g. http://localhost:4318. Unset means off.
CLICKSTACK_OTLP_URL=

# Deployed instances only: comma-separated access codes plus the cookie
# secret behind the /gate page. Leave both unset to run without a gate.
ACCESS_CODES=
ACCESS_TOKEN_SECRET=
