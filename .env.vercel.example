# Environment for the Next.js app on Vercel. Fill in, then import into the
# project (Settings > Environment Variables > Import .env). The full variable
# matrix lives in docs/DEPLOYMENT.md.

DATABASE_URL=
DATABASE_URL_CONNECTION_POOLING=

CLICKHOUSE_URL=
CLICKHOUSE_READER_PASSWORD=
# Optional: also set CLICKHOUSE_TELEMETRY_PASSWORD to record the app's own
# instrument executions as telemetry spans.

RENDER_TOKEN_SECRET=
# Your public origin, e.g. https://rendi.example.com
RENDI_APP_URL=

TRIGGER_SECRET_KEY=

# The access gate; leave unset for an open instance
ACCESS_CODES=
ACCESS_TOKEN_SECRET=
