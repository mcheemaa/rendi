{
	"name": "rendi",
	"version": "0.1.0",
	"private": true,
	"description": "Questions become interfaces: a chat agent whose answers are live, steerable instruments over ClickHouse, on Trigger.dev durable sessions.",
	"license": "MIT",
	"homepage": "https://rendi.help",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mcheemaa/rendi.git"
	},
	"packageManager": "pnpm@10.25.0",
	"engines": {
		"node": "^24"
	},
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"lint": "biome check .",
		"format": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:storybook": "vitest --project storybook run",
		"db:generate": "node --env-file=.env.development.local node_modules/drizzle-kit/bin.cjs generate",
		"db:migrate": "node --env-file=.env.development.local node_modules/drizzle-kit/bin.cjs migrate"
	},
