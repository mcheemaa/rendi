		"@neondatabase/serverless": "^1.1.0",
		"@tanstack/react-virtual": "^3.14.7",
		"@trigger.dev/core": "4.5.4",
		"@trigger.dev/sdk": "4.5.4",
		"ai": "^7.0.31",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
