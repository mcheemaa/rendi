		"motion": "^12.42.2",
		"nanoid": "^6.0.0",
		"next": "16.2.10",
		"next-themes": "^0.4.6",
		"react": "19.2.4",
		"react-day-picker": "^10.0.1",
		"react-dom": "19.2.4",
		"resend": "^6.18.0",
