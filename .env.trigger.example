# Environment for the Trigger.dev workers. Fill in, then add to the project's
# environment variables in the Trigger.dev dashboard before deploying. The
# full variable matrix lives in docs/DEPLOYMENT.md.

ANTHROPIC_API_KEY=
GEMINI_API_KEY=

DATABASE_URL=

CLICKHOUSE_URL=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_READER_PASSWORD=
CLICKHOUSE_TELEMETRY_PASSWORD=

RESEND_API_KEY=
RENDER_TOKEN_SECRET=
RENDI_MODEL=claude-opus-4-8

# Must be the public app origin; screenshot and image tools persist absolute
# URLs built from it and fail fast in production without it.
RENDI_APP_URL=

GITHUB_TOKEN=
